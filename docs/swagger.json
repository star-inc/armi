                },
                "last_modified": {
                    "type": "string"
                }
            }
        },
        "contract.UpdateFileMetadataRequest": {
            "type": "object",
            "properties": {
                "description": {
                    "type": "string"
                },
                "filename": {
                    "type": "string"
                },
                "group_ids": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "tags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
