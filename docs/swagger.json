        },
        "contract.UpdateMeRequest": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "http.StreamResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                }
            }
